<script>
const API_KEY='AIzaSyCnbxeCPIc_QSpA382a1OZD7YM0sylUogo';
let stops=[],dirService,dirRenderer,mapsLoaded=false;
let urgSel='12',impUrg='12';
let editingNoteIdx=null,falloIdx=null,alertVozInterval=null;
let vozSeleccionada=null,vozRate=0.85;
const STORAGE_KEY='rutas_activas_v5';

// ── NUMS EN LETRAS ──
const NUMS={'cero':0,'uno':1,'una':1,'dos':2,'tres':3,'cuatro':4,'cinco':5,'seis':6,'siete':7,'ocho':8,'nueve':9,'diez':10,'once':11,'doce':12,'trece':13,'catorce':14,'quince':15,'dieciséis':16,'dieciseis':16,'diecisiete':17,'dieciocho':18,'diecinueve':19,'veinte':20,'veintiuno':21,'veintidós':22,'veintidos':22,'veintitrés':23,'veintitres':23,'veinticuatro':24,'veinticinco':25,'veintiséis':26,'veintiseis':26,'veintisiete':27,'veintiocho':28,'veintinueve':29,'treinta':30,'cuarenta':40,'cincuenta':50,'sesenta':60,'setenta':70,'ochenta':80,'noventa':90,'cien':100,'ciento':100};
function convNums(t){t=t.replace(/n[uú]mero\s+/gi,'');const p=Object.keys(NUMS).sort((a,b)=>b.length-a.length);for(const w of p)t=t.replace(new RegExp('\\b'+w+'\\b','gi'),NUMS[w]);return t.replace(/\s+/g,' ').trim();}

// ── UTILS ──
function selUrg(u){urgSel=u;document.querySelectorAll('[data-urg]').forEach(b=>b.classList.remove('sel'));document.querySelector(`[data-urg="${u}"]`).classList.add('sel');}
function selImpUrg(u){impUrg=u;document.querySelectorAll('[data-iurg]').forEach(b=>b.classList.remove('sel'));document.querySelector(`[data-iurg="${u}"]`).classList.add('sel');}
function save(){localStorage.setItem(STORAGE_KEY,JSON.stringify(stops));}
function load(){try{const s=localStorage.getItem(STORAGE_KEY);if(s)stops=JSON.parse(s);}catch{}}
function getTodayStr(){return new Date().toISOString().split('T')[0];}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

// ── FECHA ──
function updateDate(){
  const n=new Date();
  const dias=['DOM','LUN','MAR','MIÉ','JUE','VIE','SÁB'];
  const meses=['ENE','FEB','MAR','ABR','MAY','JUN','JUL','AGO','SEP','OCT','NOV','DIC'];
  document.getElementById('hoy-fecha').textContent=`${String(n.getDate()).padStart(2,'0')} ${meses[n.getMonth()]} ${n.getFullYear()}`;
  document.getElementById('hoy-dia').textContent=dias[n.getDay()];
}

// ── VOZ ──
function hablar(txt){
  const speak=()=>{try{window.speechSynthesis.cancel();const m=new SpeechSynthesisUtterance(txt);m.lang='es-ES';m.rate=vozRate||0.85;m.pitch=1;m.volume=1;if(vozSeleccionada)m.voice=vozSeleccionada;window.speechSynthesis.speak(m);}catch{}};
  speak();setTimeout(speak,600);
}
function cargarVoces(){
  const voces=window.speechSynthesis.getVoices();
  const sel=document.getElementById('sel-voz');
  if(!sel)return;
  sel.innerHTML='';
  const vozGuardada=localStorage.getItem('vozNombre');
  const espa=voces.filter(v=>v.lang.startsWith('es'));
  const lista=espa.length>0?espa:voces;
  lista.forEach(v=>{const opt=document.createElement('option');opt.value=v.name;opt.textContent=`${v.name} (${v.lang})`;if(v.name===vozGuardada)opt.selected=true;sel.appendChild(opt);});
  const rateG=localStorage.getItem('vozRate');
  if(rateG){vozRate=parseFloat(rateG);document.getElementById('voz-rate').value=vozRate;document.getElementById('voz-rate-val').textContent=vozRate;}
  if(vozGuardada)vozSeleccionada=lista.find(v=>v.name===vozGuardada)||null;
}
function showVozModal(){document.getElementById('modal-voz').classList.add('open');setTimeout(cargarVoces,200);}
function previewVoz(){
  const sel=document.getElementById('sel-voz');
  const rate=parseFloat(document.getElementById('voz-rate').value);
  const voces=window.speechSynthesis.getVoices();
  const voz=voces.find(v=>v.name===sel.value);
  try{window.speechSynthesis.cancel();const m=new SpeechSynthesisUtterance('Atención. Prueba de voz. Uno dos tres.');m.lang='es-ES';m.rate=rate;m.pitch=1;m.volume=1;if(voz)m.voice=voz;window.speechSynthesis.speak(m);}catch{}
}
function guardarVoz(){
  const sel=document.getElementById('sel-voz');
  const rate=parseFloat(document.getElementById('voz-rate').value);
  const voces=window.speechSynthesis.getVoices();
  vozSeleccionada=voces.find(v=>v.name===sel.value)||null;
  vozRate=rate;
  localStorage.setItem('vozNombre',sel.value);
  localStorage.setItem('vozRate',rate);
  closeModal('voz');
  toast('✅ Voz guardada','#00e676','#060d1a');
}
if(window.speechSynthesis){
  if(typeof window.speechSynthesis.onvoiceschanged!=='undefined'){window.speechSynthesis.onvoiceschanged=cargarVoces;}
  else{setTimeout(cargarVoces,500);}
}

// ── TOAST ──
function toast(msg,color='#ff7b00',tc='#060d1a'){const d=document.createElement('div');d.className='notif-toast';d.style.background=color;d.style.color=tc;d.textContent=msg;document.body.appendChild(d);setTimeout(()=>d.remove(),8000);}

// ── POPUPS ──
function mostrarWarn(hora,titulo,msg,voz){
  document.getElementById('pw-time').textContent=hora;
  document.getElementById('pw-title').textContent=titulo;
  document.getElementById('pw-msg').textContent=msg;
  document.getElementById('popup-warn').classList.add('open');
  hablar(voz);
}
function mostrarAlert(hora,titulo,sancion,msg,voz){
  document.getElementById('pa-time').textContent=hora;
  document.getElementById('pa-title').textContent=titulo;
  const se=document.getElementById('pa-sancion');
  if(sancion){se.textContent=sancion;se.style.display='block';}else se.style.display='none';
  document.getElementById('pa-msg').textContent=msg;
  document.getElementById('popup-alert').classList.add('open');
  hablar(voz);
  if(alertVozInterval)clearInterval(alertVozInterval);
  alertVozInterval=setInterval(()=>{if(document.getElementById('popup-alert').classList.contains('open'))hablar(voz);else{clearInterval(alertVozInterval);alertVozInterval=null;}},30000);
}
function mostrarSuccess(hora,titulo,msg,voz){
  document.getElementById('ps-time').textContent=hora;
  document.getElementById('ps-title').textContent=titulo;
  document.getElementById('ps-msg').textContent=msg;
  document.getElementById('popup-success').classList.add('open');
  hablar(voz);
}
function cerrarPopup(tipo){
  document.getElementById('popup-'+tipo).classList.remove('open');
  if(tipo==='alert'&&alertVozInterval){clearInterval(alertVozInterval);alertVozInterval=null;}
}

