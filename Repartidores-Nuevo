}

// ── RENDER ──
const urgBadge={'12':'<span class="tag b12">🟠 12h</span>','14':'<span class="tag b14">🔴 14h</span>','19':'<span class="tag b19">🔵 19h</span>','rec14':'<span class="tag brec14">📤 Recog.14h</span>','rec18':'<span class="tag brec18">📤 Recog.18h</span>'};
const urgOrder={'rec14':0,'rec18':1,'12':2,'14':3,'19':4,'normal':5};

function render(){
  const list=document.getElementById('stops-list');
  const btn=document.getElementById('btn-opt');
  const today=getTodayStr();
  if(!stops.length){list.innerHTML='<div class="empty-stops"><div class="empty-icon">📦</div>Añade paradas<br>y pulsa OPTIMIZAR</div>';btn.disabled=true;updateStats();return;}
  const active=stops.filter(s=>!s.completada&&!s.aplazado);
  btn.disabled=active.length<2;
  const sorted=[...stops].sort((a,b)=>{
    if(a.completada!==b.completada)return a.completada?1:-1;
    const aAyer=a.aplazado&&a.fechaAplazado&&a.fechaAplazado<today;
    const bAyer=b.aplazado&&b.fechaAplazado&&b.fechaAplazado<today;
    if(aAyer!==bAyer)return aAyer?-1:1;
    if(a.aplazado!==b.aplazado)return a.aplazado?1:-1;
    return urgOrder[a.urgente]-urgOrder[b.urgente];
  });
  let numPend=0;
  const isStart=(s)=>active.length>=2&&s.id===active[0].id;
  list.innerHTML=sorted.map((s)=>{
    const oi=stops.indexOf(s);
    const esAyer=s.aplazado&&s.fechaAplazado&&s.fechaAplazado<today;
    const esHoy=s.aplazado&&s.fechaAplazado===today;
    const sem=getSemaforo(s);
    const tieneFallos=s.fallos&&s.fallos.length>0;
    const esRecogida=s.urgente==='rec14'||s.urgente==='rec18';
    let numDisplay='✓';
    if(!s.completada&&!s.aplazado){numPend++;numDisplay=numPend;}
    else if(s.aplazado&&!s.completada)numDisplay='⏸';
    let cls='stop-card ';
    if(s.completada)cls+='completed';
    else if(esAyer)cls+=sem==='aplazado-crit'?'aplazado-critical':'aplazado-priority';
    else if(esHoy)cls+='aplazado-card';
    else if(tieneFallos)cls+='fallida';
    else cls+=`urg-${s.urgente}`;
    let estadoBadge='';
    if(esAyer)estadoBadge=sem==='aplazado-crit'?'<span class="tag t-aplazado-crit">🔴 ENTREGAR HOY</span>':'<span class="tag t-aplazado-warn">🟡 APLAZADO — Prioridad</span>';
    else if(esHoy)estadoBadge='<span class="tag t-aplazado">🟢 APLAZADO</span>';
    const fallosHtml=tieneFallos?s.fallos.map(f=>`<div class="fallo-item">⚠️ Intento ${f.intento} — ${f.hora}${f.nota?' — '+esc(f.nota):''}</div>`).join(''):'';
    const btnAplazar=!esRecogida&&!s.completada?`<button onclick="aplazar(${oi})" class="btn-aplazar ${sem}" ${s.aplazado?'disabled':''}>${s.aplazado?'✅ Aplazado':'🟢 Aplazar'}</button>`:'';
    const btnRecoger=esRecogida&&!s.completada?`<button onclick="marcarRecogida(${oi})" class="btn-aplazar ${s.recogido?'aplazado-ok':'sem-green'}" ${s.recogido?'disabled':''}>${s.recogido?'✅ Recogido':'📤 Marcar Recogida'}</button>`:'';
    return `<div class="${cls}">
      <div class="stop-num ${s.completada?'done':''}">${numDisplay}</div>
      <div class="stop-body">
        <div class="stop-id" style="color:${getIdColor(s.urgente)}">#${String(s.pkgId||0).padStart(3,'0')}</div>
        <div class="stop-dir">${esc(s.direccion)}</div>
        <div class="stop-tags">
          ${urgBadge[s.urgente]||''}
          ${isStart(s)?'<span class="tag bstart">🟢 INICIO</span>':''}
          ${estadoBadge}
          ${tieneFallos?`<span class="tag" style="background:rgba(255,23,68,0.12);color:var(--fail);border-color:var(--fail)">⚠️ ${s.fallos.length} FALLO${s.fallos.length>1?'S':''}</span>`:''}
        </div>
        ${fallosHtml}
        ${s.nota?`<div class="stop-note">📝 ${esc(s.nota)}</div>`:''}
        ${!s.completada?`<div class="stop-btns">
          <div class="stop-btns-row">
            <button onclick="navegar(${oi})" class="btn-nav">🧭 Navegar</button>
            ${!esRecogida?`<button onclick="openFallo(${oi})" class="btn-fallo-card">⚠️ Fallo</button>`:''}
          </div>
          ${btnAplazar?`<div class="stop-btns-row">${btnAplazar}</div>`:''}
          ${btnRecoger?`<div class="stop-btns-row">${btnRecoger}</div>`:''}
        </div>`:''}
      </div>
      <div class="stop-actions">
        <button class="icon-btn" onclick="openNota(${oi})">📝</button>
        <button class="icon-btn" onclick="toggle(${oi})" style="color:${!s.completada?'var(--done)':'var(--muted)'}">${s.completada?'↩':'✓'}</button>
        <button class="icon-btn" onclick="del(${oi})" style="color:var(--fail)">✕</button>
      </div>
    </div>`;
  }).join('');
  updateStats();
}

function aplazar(i){if(stops[i].aplazado)return;stops[i].aplazado=true;stops[i].fechaAplazado=getTodayStr();save();render();toast('🟢 Aplazado correctamente','#00e676','#060d1a');}
function marcarRecogida(i){
  stops[i].recogido=true;stops[i].horaRecogida=new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});
  save();render();
  mostrarAlert(stops[i].horaRecogida,'⚠️ Cierra la recogida en la PDA','',`Recogida a las ${stops[i].horaRecogida}. Asegúrate de cerrarla en la PDA ahora mismo o no la cobrarás.`,'Atención. Asegúrate de cerrar la recogida en la PDA ahora mismo. Si no la cierras no la cobrarás.');
}
function del(i){stops.splice(i,1);save();render();}
function toggle(i){stops[i].completada=!stops[i].completada;if(stops[i].completada)stops[i].aplazado=false;save();render();}
function navegar(i){window.open(`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(stops[i].direccion)}&travelmode=driving&dir_action=navigate`,'_blank');}

function updateStats(){
  const total=stops.length,done=stops.filter(s=>s.completada).length;
  const aplazados=stops.filter(s=>s.aplazado&&!s.completada).length;
  const pendientes=stops.filter(s=>!s.completada&&!s.aplazado).length;
  const pct=total?Math.round(done/total*100):0;
  document.getElementById('prog-fill').style.width=pct+'%';
  document.getElementById('prog-txt').textContent=`${done}/${total}`;
  const ae=document.getElementById('prog-aplazado');
  if(aplazados>0){ae.style.display='block';ae.textContent=`🟢 ${aplazados} aplaz.`;}else ae.style.display='none';
  document.getElementById('stat-par').textContent=pendientes;
}

// ── OPTIMIZAR ──
function showOptModal(){
  const active=stops.filter(s=>!s.completada&&!s.aplazado);
  if(active.length<2){alert('Necesitas al menos 2 paradas.');return;}
  const si=document.getElementById('sel-inicio');si.innerHTML='';
  active.forEach((s,i)=>{si.innerHTML+=`<option value="${s.id}">${i+1}. ${s.direccion.substring(0,42)}${s.direccion.length>42?'...':''}</option>`;});
  si.value=active[0].id;
  document.getElementById('modal-opt').classList.add('open');
}
function getStart(){
  const active=stops.filter(s=>!s.completada&&!s.aplazado);
  const startId=Number(document.getElementById('sel-inicio').value);
  return{startStop:active.find(s=>s.id===startId),rest:active.filter(s=>s.id!==startId)};
}
function optimizarDistancia(){
  closeModal('opt');
  if(!mapsLoaded||!dirService){alert('Cargando mapa...');return;}
  const{startStop,rest}=getStart();
  if(!rest.length)return;
  const last=rest[rest.length-1];
  dirService.route({origin:startStop.direccion,destination:last.direccion,waypoints:rest.slice(0,-1).map(s=>({location:s.direccion,stopover:true})),optimizeWaypoints:true,travelMode:google.maps.TravelMode.DRIVING,region:'es'},(result,status)=>{
    if(status==='OK'){
      let d=0,t=0;result.routes[0].legs.forEach(l=>{d+=l.distance.value;t+=l.duration.value;});
      document.getElementById('stat-dist').textContent=(d/1000).toFixed(1)+'km';
      const m=Math.round(t/60);document.getElementById('stat-time').textContent=m<60?m+'min':Math.floor(m/60)+'h'+(m%60)+'m';
      const wo=result.routes[0].waypoint_order;
      const reordered=[startStop,...wo.map(i=>rest.slice(0,-1)[i]),last];
      stops=[...reordered,...stops.filter(s=>s.completada||s.aplazado)];
      save();render();toast('🗺️ Ruta optimizada por distancia','#00b0ff','#fff');
    }else alert('Error: '+status);
  });
}
function optimizarUrgencia(){
  closeModal('opt');
  if(!mapsLoaded||!dirService){alert('Cargando mapa...');return;}
  const{startStop,rest}=getStart();
  const b12=rest.filter(s=>s.urgente==='12');
  const b14=rest.filter(s=>s.urgente==='14');
  const b19=rest.filter(s=>s.urgente==='19');
  const bR=rest.filter(s=>s.urgente==='rec14'||s.urgente==='rec18');
  const bN=rest.filter(s=>s.urgente==='normal');
  const ruta=[startStop,...bR,...b12,...b14,...b19,...bN];
  if(ruta.length<2)return;
  const last=ruta[ruta.length-1];
  dirService.route({origin:ruta[0].direccion,destination:last.direccion,waypoints:ruta.slice(1,-1).map(s=>({location:s.direccion,stopover:true})),optimizeWaypoints:false,travelMode:google.maps.TravelMode.DRIVING,region:'es'},(result,status)=>{
    if(status==='OK'){
      let d=0,t=0;result.routes[0].legs.forEach(l=>{d+=l.distance.value;t+=l.duration.value;});
      document.getElementById('stat-dist').textContent=(d/1000).toFixed(1)+'km';
      const m=Math.round(t/60);document.getElementById('stat-time').textContent=m<60?m+'min':Math.floor(m/60)+'h'+(m%60)+'m';
      stops=[...ruta,...stops.filter(s=>s.completada||s.aplazado)];
      save();render();toast('⏰ Ruta por urgencia','#ff7b00','#060d1a');
    }else alert('Error: '+status);
  });
}

