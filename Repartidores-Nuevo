<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Rutas Activas — Repartidor</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#060d1a; --surface:#0a1628; --surface2:#0f1f38;
  --border:#1e3556; --border2:#2a4a70;
  --orange:#ff7b00; --orange2:#ff9a33;
  --nav-green:#39ff14;
  --urg12:#ff8c00; --urg14:#ff1744; --urg19:#00b0ff;
  --rec14:#9c27b0; --rec18:#e91e63;
  --done:#00e676; --fail:#ff1744; --amber:#ffca28;
  --text:#e3f0ff; --text2:#a8c4e0; --muted:#4a6a8a; --white:#ffffff;
  --font-head:'Exo 2',sans-serif; --font-mono:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}

/* ── PÁGINA COMPLETA ── */
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:var(--font-head);display:flex;flex-direction:column;}

/* ── HEADER ── */
header{flex-shrink:0;background:var(--surface);border-bottom:2px solid var(--border2);}
.header-main{display:flex;justify-content:space-between;align-items:center;padding:10px 14px 8px;}
.brand-tag{font-family:var(--font-mono);font-size:8px;letter-spacing:4px;color:var(--urg19);text-transform:uppercase;opacity:0.7;}
.brand-name{font-size:22px;font-weight:900;color:var(--white);letter-spacing:2px;text-transform:uppercase;line-height:1;}
.brand-name span{color:var(--orange);}
.header-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;}
.clock-date{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--urg19);letter-spacing:2px;}
.clock-day{font-family:var(--font-mono);font-size:9px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;}
.btn-voz{background:transparent;border:1px solid var(--border2);border-radius:4px;color:var(--muted);font-family:var(--font-mono);font-size:9px;padding:3px 7px;cursor:pointer;letter-spacing:1px;text-transform:uppercase;}

/* ── 4 CAJITAS ALARMA ── */
.alarm-strip{display:flex;border-top:1px solid var(--border);}
.alarm-cell{flex:1;padding:8px 4px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;border-right:1px solid var(--border);position:relative;overflow:hidden;transition:all 0.3s;}
.alarm-cell:last-child{border-right:none;}
.alarm-cell.ok{background:var(--surface2);}
.alarm-cell.warn{background:rgba(255,202,40,0.1);animation:cellWarn 1.5s infinite;}
.alarm-cell.alert{background:rgba(255,23,68,0.12);animation:cellAlert 0.7s infinite;}
@keyframes cellWarn{0%,100%{background:rgba(255,202,40,0.1)}50%{background:rgba(255,202,40,0.22)}}
@keyframes cellAlert{0%,100%{background:rgba(255,23,68,0.12)}50%{background:rgba(255,23,68,0.28)}}
.alarm-cell::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--border);}
.alarm-cell.warn::after{background:var(--amber);animation:barP 1.5s infinite;}
.alarm-cell.alert::after{background:var(--fail);animation:barP 0.7s infinite;}
@keyframes barP{0%,100%{opacity:1}50%{opacity:0.2}}
.alarm-icon{font-size:16px;line-height:1;}
.alarm-time{font-family:var(--font-mono);font-size:12px;font-weight:700;letter-spacing:1px;line-height:1;}
.alarm-cell.ok .alarm-time{color:var(--muted);}
.alarm-cell.warn .alarm-time{color:var(--amber);}
.alarm-cell.alert .alarm-time{color:var(--fail);}
.alarm-desc{font-family:var(--font-mono);font-size:7px;letter-spacing:0.5px;text-transform:uppercase;text-align:center;line-height:1.3;}
.alarm-cell.ok .alarm-desc{color:var(--muted);}
.alarm-cell.warn .alarm-desc{color:var(--amber);}
.alarm-cell.alert .alarm-desc{color:var(--fail);}

/* ── CUERPO PRINCIPAL — FLEX COLUMN ── */
.app-body{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0;}

/* ── SECCIÓN AÑADIR ── */
.add-section{flex-shrink:0;background:var(--surface2);border-bottom:1px solid var(--border);}
.add-section-header{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;cursor:pointer;user-select:none;}
.box-title{font-family:var(--font-mono);font-size:8px;letter-spacing:4px;color:var(--urg19);text-transform:uppercase;display:flex;align-items:center;gap:8px;flex:1;}
.box-title::after{content:'';flex:1;height:1px;background:var(--border);}
.btn-toggle-add{background:transparent;border:1px solid var(--border2);border-radius:4px;color:var(--urg19);font-size:14px;width:26px;height:26px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform 0.25s,background 0.15s;flex-shrink:0;}
.btn-toggle-add:hover{background:rgba(0,176,255,0.1);}
.btn-toggle-add.collapsed{transform:rotate(-90deg);}
.add-section-body{padding:0 12px 10px;overflow:hidden;transition:max-height 0.3s ease,opacity 0.25s ease,padding 0.25s ease;}
.add-section-body.hidden{max-height:0!important;opacity:0;padding-bottom:0;pointer-events:none;}

input[type="text"]{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:6px;padding:12px 13px;color:var(--white);font-family:var(--font-mono);font-size:14px;outline:none;transition:all 0.2s;margin-bottom:8px;}
input[type="text"]:focus{border-color:var(--urg19);box-shadow:0 0 0 3px rgba(0,176,255,0.12);}
input[type="text"]::placeholder{color:var(--muted);}

/* BOTONES URGENTE — 2 columnas sin Normal */
.urg-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:8px;}
.urg-btn{padding:11px 6px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--muted);font-family:var(--font-mono);font-size:11px;font-weight:700;cursor:pointer;text-align:center;transition:all 0.15s;}
.urg-btn:hover{border-color:var(--orange);color:var(--orange);}
.urg-btn.btn-jornada{border-color:rgba(255,202,40,0.35);color:var(--amber);}
.urg-btn.btn-jornada:hover{background:rgba(255,202,40,0.15);border-color:var(--amber);color:var(--amber);}
.urg-btn[data-urg="12"].sel{background:rgba(255,140,0,0.15);border-color:var(--urg12);color:var(--urg12);}
.urg-btn[data-urg="14"].sel{background:rgba(255,23,68,0.15);border-color:var(--urg14);color:var(--urg14);}
.urg-btn[data-urg="19"].sel{background:rgba(0,176,255,0.15);border-color:var(--urg19);color:var(--urg19);}
.urg-btn[data-urg="rec14"].sel{background:rgba(156,39,176,0.15);border-color:var(--rec14);color:var(--rec14);}
.urg-btn[data-urg="rec18"].sel{background:rgba(233,30,99,0.15);border-color:var(--rec18);color:var(--rec18);}

.btn-row{display:flex;gap:6px;margin-bottom:6px;}
.btn-add{flex:1;padding:11px;background:rgba(255,123,0,0.12);border:1px solid var(--orange);border-radius:6px;color:var(--orange);font-family:var(--font-head);font-size:14px;font-weight:800;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;}
.btn-add:hover{background:var(--orange);color:var(--bg);}
.btn-opt{flex:1;padding:11px;background:var(--orange);border:1px solid var(--orange);border-radius:6px;color:var(--bg);font-family:var(--font-head);font-size:14px;font-weight:800;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;box-shadow:0 0 16px rgba(255,123,0,0.25);}
.btn-opt:hover{background:var(--orange2);}
.btn-opt:disabled{background:var(--surface);color:var(--muted);border-color:var(--border);box-shadow:none;cursor:not-allowed;}
.btn-import{width:100%;padding:8px;background:transparent;border:1px solid var(--border2);border-radius:6px;color:var(--text2);font-family:var(--font-mono);font-size:11px;letter-spacing:1px;cursor:pointer;transition:all 0.15s;text-transform:uppercase;}
.btn-import:hover{border-color:var(--urg19);color:var(--urg19);}

/* ── BARRA DE PROGRESO Y STATS ── */
.stats-bar{flex-shrink:0;display:flex;align-items:center;gap:10px;padding:5px 12px;background:var(--surface);border-bottom:1px solid var(--border);flex-wrap:wrap;}
.stat-item{display:flex;align-items:center;gap:4px;}
.stat-lbl{font-family:var(--font-mono);font-size:9px;letter-spacing:1px;color:var(--muted);text-transform:uppercase;}
.stat-val{font-family:var(--font-head);font-size:15px;font-weight:900;color:var(--orange);}
.prog-track{flex:1;min-width:60px;height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--urg19),var(--nav-green));border-radius:2px;transition:width 0.4s;}
.prog-txt{font-family:var(--font-mono);font-size:10px;color:var(--muted);white-space:nowrap;}
.prog-aplazado{font-family:var(--font-mono);font-size:10px;color:var(--done);white-space:nowrap;font-weight:700;display:none;}

/* ── LISTA DE PARADAS — OCUPA TODO EL ESPACIO RESTANTE ── */
.stops-list{flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:6px;min-height:0;min-height:50vh;}
.stops-list::-webkit-scrollbar{width:3px;}
.stops-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* ── BARRA INFERIOR ── */
.bottom-bar{flex-shrink:0;padding:8px 12px;border-top:1px solid var(--border);background:var(--surface);}
.btn-new-day{width:100%;background:transparent;border:1px solid var(--border);border-radius:5px;color:var(--muted);font-family:var(--font-mono);font-size:10px;letter-spacing:2px;padding:9px;cursor:pointer;text-transform:uppercase;transition:all 0.15s;}
.btn-new-day:hover{border-color:var(--amber);color:var(--amber);}

/* ── LEGEND ── */
.legend{flex-shrink:0;display:flex;gap:8px;flex-wrap:wrap;padding:4px 12px;background:var(--bg);border-bottom:1px solid var(--border);}
.legend-item{display:flex;align-items:center;gap:3px;font-family:var(--font-mono);font-size:9px;color:var(--muted);}
.legend-dot{width:6px;height:6px;border-radius:1px;flex-shrink:0;}

/* ── TARJETA PARADA ── */
.stop-card{background:var(--surface2);border:1px solid var(--border);border-left:5px solid var(--border);border-radius:8px;padding:12px 12px 12px 14px;display:flex;align-items:flex-start;gap:10px;transition:all 0.15s;}
.stop-card.urg-12{border-left-color:var(--urg12);}
.stop-card.urg-14{border-left-color:var(--urg14);}
.stop-card.urg-19{border-left-color:var(--urg19);}
.stop-card.urg-rec14{border-left-color:var(--rec14);}
.stop-card.urg-rec18{border-left-color:var(--rec18);}
.stop-card.normal-card{border-left-color:var(--done);}
.stop-card.completed{opacity:0.35;}
.stop-card.aplazado-card{border-left-color:var(--done);background:rgba(0,230,118,0.06);border-color:rgba(0,230,118,0.2);}
.stop-card.aplazado-priority{border-left-color:var(--amber);background:rgba(255,202,40,0.06);border-color:rgba(255,202,40,0.25);}
.stop-card.aplazado-critical{border-left-color:var(--fail);background:rgba(255,23,68,0.06);animation:cardCrit 0.8s infinite;}
@keyframes cardCrit{0%,100%{background:rgba(255,23,68,0.06)}50%{background:rgba(255,23,68,0.14)}}
.stop-card.fallida{border-left-color:var(--fail);background:rgba(255,23,68,0.04);}
.stop-num{font-family:var(--font-mono);font-size:20px;font-weight:700;color:var(--orange);min-width:28px;line-height:1;padding-top:3px;}
.stop-num.done{color:var(--done);}
.stop-body{flex:1;min-width:0;}
.stop-id{font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:2px;margin-bottom:4px;text-transform:uppercase;}
.stop-dir{font-size:15px;font-weight:700;color:var(--white);white-space:normal;word-break:break-word;line-height:1.3;margin-bottom:6px;}
.stop-tags{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px;}
.tag{font-family:var(--font-mono);font-size:9px;font-weight:700;padding:3px 8px;border-radius:3px;letter-spacing:1px;text-transform:uppercase;border:1px solid;}
.b12{background:rgba(255,140,0,0.12);color:var(--urg12);border-color:var(--urg12);}
.b14{background:rgba(255,23,68,0.12);color:var(--urg14);border-color:var(--urg14);}
.b19{background:rgba(0,176,255,0.12);color:var(--urg19);border-color:var(--urg19);}
.brec14{background:rgba(156,39,176,0.12);color:var(--rec14);border-color:var(--rec14);}
.brec18{background:rgba(233,30,99,0.12);color:var(--rec18);border-color:var(--rec18);}
.bstart{background:rgba(0,230,118,0.12);color:var(--done);border-color:var(--done);}
.t-aplazado{background:rgba(0,230,118,0.2);color:var(--done);border-color:var(--done);padding:3px 10px;animation:tagGlow 2s infinite;}
@keyframes tagGlow{0%,100%{box-shadow:none}50%{box-shadow:0 0 8px rgba(0,230,118,0.4)}}
.t-aplazado-warn{background:rgba(255,202,40,0.15);color:var(--amber);border-color:var(--amber);padding:3px 10px;}
.t-aplazado-crit{background:rgba(255,23,68,0.15);color:var(--fail);border-color:var(--fail);padding:3px 10px;animation:tagCrit 0.6s infinite;}
@keyframes tagCrit{0%,100%{opacity:1}50%{opacity:0.5}}
.stop-note{font-family:var(--font-mono);font-size:11px;color:var(--amber);margin-top:4px;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.fallo-item{font-family:var(--font-mono);font-size:10px;color:var(--fail);margin-top:3px;padding:3px 7px;background:rgba(255,23,68,0.08);border-radius:3px;border-left:2px solid var(--fail);}
.btn-nav{display:inline-flex;align-items:center;gap:5px;padding:8px 14px;background:rgba(57,255,20,0.12);border:1px solid var(--nav-green);border-radius:5px;color:var(--nav-green);font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;box-shadow:0 0 10px rgba(57,255,20,0.12);}
.btn-nav:hover{background:var(--nav-green);color:var(--bg);}
.btn-fallo-card{display:inline-flex;align-items:center;gap:5px;padding:8px 12px;background:transparent;border:1px solid rgba(255,23,68,0.35);border-radius:5px;color:rgba(255,23,68,0.7);font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;}
.btn-fallo-card:hover{background:var(--fail);color:#fff;border-color:var(--fail);}
.btn-aplazar{display:inline-flex;align-items:center;gap:5px;padding:8px 12px;border-radius:5px;font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:1px solid;transition:all 0.2s;}
.btn-aplazar.sem-green{background:rgba(0,230,118,0.12);border-color:var(--done);color:var(--done);}
.btn-aplazar.sem-green:hover{background:var(--done);color:var(--bg);}
.btn-aplazar.sem-green-blink{background:rgba(0,230,118,0.12);border-color:var(--done);color:var(--done);animation:semGB 1.5s infinite;}
@keyframes semGB{0%,100%{box-shadow:0 0 0 0 rgba(0,230,118,0)}50%{box-shadow:0 0 14px 4px rgba(0,230,118,0.4)}}
.btn-aplazar.sem-amber{background:rgba(255,202,40,0.15);border-color:var(--amber);color:var(--amber);animation:semA 1s infinite;}
@keyframes semA{0%,100%{box-shadow:0 0 0 0 rgba(255,202,40,0)}50%{box-shadow:0 0 16px 4px rgba(255,202,40,0.5)}}
.btn-aplazar.sem-red{background:rgba(255,23,68,0.2);border-color:var(--fail);color:var(--fail);animation:semR 0.5s infinite;}
@keyframes semR{0%,100%{box-shadow:0 0 0 0 rgba(255,23,68,0);background:rgba(255,23,68,0.2)}50%{box-shadow:0 0 18px 5px rgba(255,23,68,0.6);background:rgba(255,23,68,0.38)}}
.btn-aplazar.aplazado-ok{background:rgba(0,230,118,0.2);border-color:var(--done);color:var(--done);cursor:default;}
.stop-btns{display:flex;flex-direction:column;gap:5px;margin-top:8px;}
.stop-btns-row{display:flex;gap:5px;flex-wrap:wrap;}
.stop-actions{display:flex;flex-direction:column;gap:4px;flex-shrink:0;}
.icon-btn{background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:4px;padding:5px 7px;cursor:pointer;font-size:12px;transition:all 0.15s;}
.icon-btn:hover{border-color:var(--urg19);color:var(--urg19);}
.empty-stops{text-align:center;padding:32px 16px;color:var(--muted);font-family:var(--font-mono);font-size:11px;letter-spacing:1px;text-transform:uppercase;line-height:2;}
.empty-icon{font-size:36px;opacity:0.2;margin-bottom:8px;}
.notif-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);padding:14px 22px;border-radius:10px;font-family:var(--font-head);font-size:15px;font-weight:800;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,0.5);max-width:90vw;text-align:center;letter-spacing:1px;}

/* ── POPUPS ── */
.popup-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9000;align-items:center;justify-content:center;padding:20px;}
.popup-overlay.open{display:flex;}
.popup{width:100%;max-width:390px;border-radius:16px;padding:28px 22px;text-align:center;animation:popIn 0.3s ease;}
@keyframes popIn{from{transform:scale(0.85);opacity:0}to{transform:scale(1);opacity:1}}
.popup.warn{background:#1a1400;border:3px solid var(--amber);box-shadow:0 0 50px rgba(255,202,40,0.35);}
.popup.alert{background:#1a0005;border:3px solid var(--fail);box-shadow:0 0 50px rgba(255,23,68,0.45);animation:popIn 0.3s ease,shake 0.5s ease 0.3s;}
.popup.success{background:#001a0a;border:3px solid var(--done);box-shadow:0 0 50px rgba(0,230,118,0.35);}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-10px)}40%{transform:translateX(10px)}60%{transform:translateX(-6px)}80%{transform:translateX(6px)}}
.popup-icon{font-size:52px;margin-bottom:8px;}
.popup-time{font-family:var(--font-head);font-size:50px;font-weight:900;letter-spacing:3px;margin-bottom:6px;line-height:1;}
.popup.warn .popup-time{color:var(--amber);}
.popup.alert .popup-time{color:var(--fail);text-shadow:0 0 25px rgba(255,23,68,0.6);}
.popup.success .popup-time{color:var(--done);}
.popup-title{font-family:var(--font-head);font-size:18px;font-weight:900;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.popup.warn .popup-title{color:var(--amber);}
.popup.alert .popup-title{color:var(--fail);}
.popup.success .popup-title{color:var(--done);}
.popup-sancion{font-family:var(--font-head);font-size:42px;font-weight:900;color:var(--fail);margin:8px 0;text-shadow:0 0 25px rgba(255,23,68,0.7);}
.popup-msg{font-family:var(--font-mono);font-size:12px;line-height:1.7;margin-bottom:20px;}
.popup.warn .popup-msg{color:#c8a800;}
.popup.alert .popup-msg{color:#ff7070;}
.popup.success .popup-msg{color:#00b356;}
.popup-btn{width:100%;padding:14px;border:none;border-radius:10px;font-family:var(--font-head);font-size:14px;font-weight:900;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;}
.popup.warn .popup-btn{background:var(--amber);color:#1a1400;}
.popup.alert .popup-btn{background:var(--fail);color:#fff;box-shadow:0 0 20px rgba(255,23,68,0.4);}
.popup.success .popup-btn{background:var(--done);color:#001a0a;}

/* ── MODALES ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:1000;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:20px;width:100%;max-width:440px;border-top:3px solid var(--orange);}
.modal h3{font-family:var(--font-head);font-size:17px;font-weight:800;color:var(--white);margin-bottom:4px;}
.modal-sub{font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-bottom:12px;}
.modal textarea{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:6px;padding:10px;color:var(--text);font-family:var(--font-mono);font-size:13px;resize:vertical;min-height:80px;outline:none;}
.modal textarea:focus{border-color:var(--urg19);}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:10px;}
.btn-mc{padding:9px 14px;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--muted);font-family:var(--font-head);font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;}
