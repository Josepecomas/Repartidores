    stops.push({direccion:dir,urgente:urg,pkgId:getNextId(),nota:'',completada:false,aplazado:false,recogido:false,fallos:[],fechaCreacion:new Date().toISOString(),fechaAplazado:null,id:Date.now()+Math.random()});
