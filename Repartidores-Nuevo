// ── AÑADIR ──
const MUNICIPIOS=['torres de cotillas','murcia','alguazas','ceuti','ceutí','lorqui','lorquí','molina'];
function getNextId(){const ids=stops.map(s=>s.pkgId||0);return(ids.length>0?Math.max(...ids):0)+1;}
function getIdColor(u){return{'12':'var(--urg12)','14':'var(--urg14)','19':'var(--urg19)','rec14':'var(--rec14)','rec18':'var(--rec18)'}[u]||'var(--done)';}

function addStop(){
  let dir=document.getElementById('input-dir').value.trim();
