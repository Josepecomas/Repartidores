function openFallo(i){falloIdx=i;document.getElementById('modal-fallo-dir').textContent=stops[i].direccion;document.getElementById('modal-fallo-textarea').value='';document.getElementById('modal-fallo').classList.add('open');}
function saveFallo(){
  if(falloIdx===null)return;
  if(!stops[falloIdx].fallos)stops[falloIdx].fallos=[];
  const n=new Date(),hora=n.getHours().toString().padStart(2,'0')+':'+n.getMinutes().toString().padStart(2,'0');
  stops[falloIdx].fallos.push({intento:stops[falloIdx].fallos.length+1,hora,nota:document.getElementById('modal-fallo-textarea').value.trim()});
  save();render();closeModal('fallo');
}

function closeModal(w){
  document.getElementById('modal-'+w).classList.remove('open');
