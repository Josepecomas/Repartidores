  const pend=stops.filter(s=>s.urgente===urg&&!s.completada&&!s.aplazado).length;
  if(pend===0){
    mostrarSuccess(hora,'✅ ¡Perfecto!',`Todos los urgentes de ${urg}h están aplazados. ¡Buen trabajo!`,`Perfecto. Todos los urgentes de ${urg.replace('rec','')} horas están aplazados. Buen trabajo.`);
  } else {
    const msg=`${a.aMsg} Tienes ${pend} urgente${pend>1?'s':''} sin aplazar.`;
    const voz=`${a.aVoz} Tienes ${pend} urgente${pend>1?'s':''} sin aplazar.`;
    mostrarAlert(a.aHora,a.aTit,a.aSancion,msg,voz);
  }
}

function updateAlarmCells(){
  const n=new Date(),t=n.getHours()*60+n.getMinutes();
  const proxWarn=ALARMAS.find(a=>{const tw=a.wH*60+a.wM;return t>=tw&&t<a.aH*60+a.aM;});
  const alAviso=document.getElementById('al-aviso');
  const alAvisoTime=document.getElementById('al-aviso-time');
  if(proxWarn){alAvisoTime.textContent=proxWarn.wHora;alAviso.className='alarm-cell warn';}
  else{const prox=ALARMAS.find(a=>t<a.wH*60+a.wM);alAvisoTime.textContent=prox?prox.wHora:'—';alAviso.className='alarm-cell ok';}
  ALARMAS.forEach(a=>{
    const cell=document.getElementById(a.celda);
    if(!cell)return;
    const tw=a.wH*60+a.wM,ta=a.aH*60+a.aM;
    if(t>=ta&&t<ta+30)cell.className='alarm-cell alert';
    else if(t>=tw&&t<ta)cell.className='alarm-cell warn';
    else cell.className='alarm-cell ok';
  });
}

function checkAlarms(){
  const n=new Date(),t=n.getHours()*60+n.getMinutes();
  ALARMAS.forEach(a=>{
    const tw=a.wH*60+a.wM,ta=a.aH*60+a.aM;
    if(t>=tw&&t<tw+5&&!firedW[a.keyW]){firedW[a.keyW]=true;mostrarWarn(a.wHora,a.wTit,a.wMsg,a.wVoz);}
    if(t<tw)firedW[a.keyW]=false;
    if(t>=ta&&t<ta+5&&!firedA[a.keyA]){firedA[a.keyA]=true;comprobarAplazamientos(a,a.aHora);}
    if(t<ta)firedA[a.keyA]=false;
  });
  updateAlarmCells();
}
function checkOnOpen(){
  const n=new Date(),t=n.getHours()*60+n.getMinutes();
  ALARMAS.forEach(a=>{
    const tw=a.wH*60+a.wM,ta=a.aH*60+a.aM;
    if(t>=tw&&t<ta&&!firedW[a.keyW]){firedW[a.keyW]=true;mostrarWarn(a.wHora,a.wTit,a.wMsg,a.wVoz);}
    if(t>=ta&&t<ta+30&&!firedA[a.keyA]){firedA[a.keyA]=true;comprobarAplazamientos(a,a.aHora);}
  });
  updateAlarmCells();
}
setInterval(checkAlarms,20000);
setInterval(updateAlarmCells,30000);

// ── SEMÁFORO ──
function getSemaforo(stop){
  const n=new Date(),t=n.getHours()*60+n.getMinutes(),today=getTodayStr(),u=stop.urgente;
  if(stop.aplazado){
    if(stop.fechaAplazado&&stop.fechaAplazado<today){
      if(t>=13*60)return 'aplazado-crit';
      return 'aplazado-warn';
    }
    return 'aplazado-ok';
  }
  if(u==='12'){if(t>=11*60+20)return 'sem-red';if(t>=11*60)return 'sem-amber';return 'sem-green';}
  if(u==='14'){if(t>=13*60+20)return 'sem-red';if(t>=13*60)return 'sem-amber';if(t>=12*60+45)return 'sem-green-blink';return 'sem-green';}
  if(u==='19'){
    const horas=(new Date()-new Date(stop.fechaCreacion||new Date()))/(1000*60*60);
    if(horas>=24){if(t>=17*60+20)return 'sem-red';if(t>=17*60)return 'sem-amber';return 'sem-green-blink';}
    if(t>=17*60+20)return 'sem-red';if(t>=17*60)return 'sem-amber';return 'sem-green';
  }
  return 'sem-green';
}

